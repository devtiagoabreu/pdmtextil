DATABASE_URL="postgresql://usuario:senha@ep-seu-host.sa-east-1.aws.neon.tech/seu_banco?sslmode=require"
NEXT_PUBLIC_APP_URL="https://pdmprotextil.vercel.app"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gerar-secret-com-openssl-rand-base64-32"
BLOB_READ_WRITE_TOKEN="colocar-depois-do-deploy"
ENCRYPTION_KEY="gerar-chave-de-32-caracteres-ou-mais"

# Google OAuth (para login com Google e integração Google Drive)
# Crie as credenciais em: https://console.cloud.google.com/apis/credentials
# Escopos OAuth necessários: openid, email, profile, https://www.googleapis.com/auth/drive.file
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"

# Evolution API (WhatsApp)
# Instância da Evolution API configurada em: https://github.com/EvolutionAPI/evolution-api
EVOLUTION_API_URL="https://sua-instancia.evolution-api.com"
EVOLUTION_API_KEY="seu-api-key"
EVOLUTION_INSTANCE_NAME="nome-da-instancia"

# Webhook do WhatsApp (compartilhado com a Evolution API/n8n)
# Usado para validar requisições recebidas no webhook
WHATSAPP_WEBHOOK_SECRET="seu-webhook-secret"
